# Application
APP_URL=http://localhost:8080
APP_ENV=development

# Database (MySQL 8+)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smappen
DB_USER=smappen
DB_PASS=changeme

# JWT Auth — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-32+ hex chars

# Google Maps Platform — enable Geocoding, Places (New), Static Maps, Maps JS
GOOGLE_API_KEY=

# OpenRouteService — https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# US Census Bureau — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# USDA AMS MyMarketNews — https://mymarketnews.ams.usda.gov/mars-api
# HTTP Basic, username=key, password=''. Used by UsdaAmsAdapter.
USDA_API_KEY=
# USDA NASS Quick Stats — https://quickstats.nass.usda.gov/api (separate
# registration; AMS keys are rejected with 401). Used by UsdaNassAdapter.
# Leave blank to skip NASS entirely (CogsBenchmarkService treats the
# adapter as disabled and the orchestrator skips it silently).
USDA_NASS_API_KEY=

# GreenDock COGS feed (spec §1a Pipe A) — Carafe-side adapter for the
# GreenDock-published landed-cost feed. Leave both blank until the
# GreenDock side ships /benchmarks; CogsBenchmarkService falls back to
# USDA + stub data silently.
COGS_FEED_URL=
COGS_FEED_KEY=

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Frontend URL (for Stripe success/cancel URLs)
FRONTEND_URL=http://localhost:5173
