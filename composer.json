{
    "name": "smappen/app",
    "description": "Smappen clone - territory mapping & demographics platform",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.10",
        "stripe/stripe-php": "^13.0",
        "vlucas/phpdotenv": "^5.6",
        "phpoffice/phpspreadsheet": "^2.0",
        "tecnickcom/tcpdf": "^6.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore",
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
